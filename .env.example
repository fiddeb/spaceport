# =============================================================================
# Spaceport - Environment Variables
# Copy this file to .env and adjust as needed.
# =============================================================================

# --------------------------------------------------------
# OpenTelemetry SDK (shared across all services)
# --------------------------------------------------------

# OTLP exporter endpoint for traces, metrics, and logs.
# Default matches the observabilitystack collector service name for Docker Compose.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Version reported as service.version in all OTel resources.
OTEL_SERVICE_VERSION=0.1.0

# --------------------------------------------------------
# Spaceport environment
# --------------------------------------------------------

# Runtime environment: local (dev.sh) | docker (docker-compose) | kubernetes (helm)
SPACEPORT_ENV=local

# --------------------------------------------------------
# Port allocation (override if defaults conflict)
# --------------------------------------------------------

# React frontend (Next.js dev server)
SPACEPORT_FRONTEND_PORT=3000

# Go REST API
SPACEPORT_API_PORT=8080

# Python pricing service (FastAPI)
SPACEPORT_PRICING_SERVICE_PORT=8000
