  "panels": [
    {
      "type": "stat",
      "title": "Number of confirmed bookings currently in the system.",
      "description": "Metric: `spaceport.booking.active`\nInstrument: updowncounter\nUnit: {booking}",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum({__name__=\"spaceport.booking.active\"})",
          "legendFormat": "spaceport.booking.active",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Number of booking attempts processed by the API.",
      "description": "Metric: `spaceport.booking.count`\nInstrument: counter\nUnit: {booking}",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
