      "description": "Metric: `spaceport.pricing.request.duration`\nInstrument: histogram\nUnit: ms",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
