{%- macro ts_class(text) -%}
{%- for i in range(0, text | length) -%}
    {%- if i == 0 or text[i-1] in ['.', '_'] -%}
        {{ text[i] | upper }}
    {%- elif not text[i] in ['.', '_'] -%}
        {{ text[i] }}
    {%- endif -%}
{%- endfor -%}
{%- endmacro -%}
{%- macro ts_var(text) -%}
{{ text | replace('.', '_') }}
{%- endmacro -%}
/**
 * Semantic convention metric instruments.
 *
 * DO NOT MODIFY: This code is autogenerated.
 * See templates/registry/typescript/metric.ts.j2.
 */

import type { Meter, {{ ctx.metrics | map(attribute='instrument') | unique | map('map_text', 'metric_type_interface') | sort | unique | join(', ') }} } from "@opentelemetry/api";
{%- for metric in ctx.metrics %}
{%- set class_name = ts_class(metric.metric_name) %}
{%- set method = metric.instrument | map_text("metric_type_method") %}

/**
 * {{ metric.brief | replace('\n', ' ') | replace('\r', '') }}
 *
 * Instrument: {{ metric.instrument }} | Unit: {{ metric.unit }}
 */
export class {{ class_name }} {
  static readonly name = "{{ metric.metric_name }}";
  static readonly unit = "{{ metric.unit }}";
  static readonly description = "{{ metric.brief | replace('\n', ' ') | replace('\r', '') }}";

  private readonly inst: {{ metric.instrument | map_text("metric_type_interface") }};

  constructor(meter: Meter) {
    this.inst = meter.{{ metric.instrument | map_text("metric_type_create") }}(
      {{ class_name }}.name,
      {
        description: {{ class_name }}.description,
        unit: {{ class_name }}.unit,
      },
    );
  }
{%- if metric.attributes is defined and metric.attributes | length > 0 %}

  {{ method }}(
    value: number,
{%- for a in metric.attributes | required | attribute_sort %}
    {{ ts_var(a.name) }}: {% if a.type is mapping %}string{% else %}{{ a.type | map_text("attribute_type_value") }}{% endif %},
{%- endfor %}
{%- if metric.attributes | not_required | list | length > 0 %}
    options?: {
{%- for a in metric.attributes | not_required | attribute_sort %}
      {{ ts_var(a.name) }}?: {% if a.type is mapping %}string{% else %}{{ a.type | map_text("attribute_type_value") }}{% endif %};
{%- endfor %}
    },
{%- endif %}
  ): void {
    const attrs: Record<string, string | number | boolean> = {
{%- for a in metric.attributes | required | attribute_sort %}
      "{{ a.name }}": {{ ts_var(a.name) }},
{%- endfor %}
    };
{%- for a in metric.attributes | not_required | attribute_sort %}
    if (options?.{{ ts_var(a.name) }} !== undefined) {
      attrs["{{ a.name }}"] = options.{{ ts_var(a.name) }};
    }
{%- endfor %}
    this.inst.{{ method }}(value, attrs);
  }
{%- else %}

  {{ method }}(value: number): void {
    this.inst.{{ method }}(value);
  }
{%- endif %}
}
{%- endfor %}
