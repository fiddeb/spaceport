{%- macro go_name(text) -%}
{%- for i in range(0, text | length) -%}
    {%- if i == 0 or text[i-1] in ['.', '_'] -%}
        {{ text[i] | upper }}
    {%- elif not text[i] in ['.', '_'] -%}
        {{ text[i] }}
    {%- endif -%}
{%- endfor -%}
{%- endmacro -%}
package semconv

import "go.opentelemetry.io/otel/attribute"

// DO NOT MODIFY: This code is autogenerated.
// See templates/registry/go/attribute.go.j2.

// --- Attribute keys ---

{% for attr in ctx.attributes | attribute_sort %}
{{ attr.brief | comment }}
const Attr{{ go_name(attr.name) }}Key = attribute.Key("{{ attr.name }}")
{% endfor %}

// --- Attribute value helpers ---

{% for attr in ctx.attributes | attribute_sort %}
{% if attr.type is mapping %}
{{ attr.brief | comment }}
func Attr{{ go_name(attr.name) }}(val string) attribute.KeyValue {
	return Attr{{ go_name(attr.name) }}Key.String(val)
}
{% elif attr.type == "string" %}
{{ attr.brief | comment }}
func Attr{{ go_name(attr.name) }}(val string) attribute.KeyValue {
	return Attr{{ go_name(attr.name) }}Key.String(val)
}
{% elif attr.type == "int" %}
{{ attr.brief | comment }}
func Attr{{ go_name(attr.name) }}(val int) attribute.KeyValue {
	return Attr{{ go_name(attr.name) }}Key.Int(val)
}
{% elif attr.type == "double" %}
{{ attr.brief | comment }}
func Attr{{ go_name(attr.name) }}(val float64) attribute.KeyValue {
	return Attr{{ go_name(attr.name) }}Key.Float64(val)
}
{% elif attr.type == "boolean" %}
{{ attr.brief | comment }}
func Attr{{ go_name(attr.name) }}(val bool) attribute.KeyValue {
	return Attr{{ go_name(attr.name) }}Key.Bool(val)
}
{% endif %}
{% endfor %}

// --- Enum values ---

{% for attr in ctx.attributes | attribute_sort %}
{% if attr.type.members is defined %}
// Enum values for {{ attr.name }}.
const (
{% for member in attr.type.members %}
    {{ member.brief | comment }}
    Attr{{ go_name(attr.name) }}{{ member.id | pascal_case }} = "{{ member.value }}"
{% endfor %}
)

{% endif %}
{% endfor %}
