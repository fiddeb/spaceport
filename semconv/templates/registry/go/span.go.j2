{%- macro go_name(text) -%}
{%- for i in range(0, text | length) -%}
    {%- if i == 0 or text[i-1] in ['.', '_'] -%}
        {{ text[i] | upper }}
    {%- elif not text[i] in ['.', '_'] -%}
        {{ text[i] }}
    {%- endif -%}
{%- endfor -%}
{%- endmacro -%}
{%- macro span_func_name(id) -%}
Start{{ go_name(id | replace("span.", "")) }}
{%- endmacro -%}
{%- macro span_const_name(id) -%}
Span{{ go_name(id | replace("span.", "")) }}Name
{%- endmacro -%}
package semconv

import (
	"context"

	"go.opentelemetry.io/otel/attribute"
	"go.opentelemetry.io/otel/trace"
)

// DO NOT MODIFY: This code is autogenerated.
// See templates/registry/go/span.go.j2.
{% for span in ctx.spans %}

// {{ span_const_name(span.id) }} is the span name for: {{ span.brief }}
const {{ span_const_name(span.id) }} = "{{ span.id | replace("span.", "") }}"

{{ span.brief | comment }}
func {{ span_func_name(span.id) }}(ctx context.Context, tracer trace.Tracer,
{%- if span.attributes is defined %}
{%- for attr in span.attributes | required | attribute_sort %}
    {{ attr.name | camel_case }} {% if attr.type is mapping %}string{% else %}{{ attr.type | map_text("attribute_type_value") }}{% endif %},
{%- endfor %}
{%- endif %}
    opts ...trace.SpanStartOption,
) (context.Context, trace.Span) {
    opts = append(opts,
        trace.WithSpanKind(trace.SpanKind{{ span.span_kind | capitalize }}),
{%- if span.attributes is defined and span.attributes | required | length > 0 %}
        trace.WithAttributes(
{%- for attr in span.attributes | required | attribute_sort %}
            attribute.{% if attr.type is mapping %}String{% else %}{{ attr.type | map_text("attribute_type_method") }}{% endif %}("{{ attr.name }}", {{ attr.name | camel_case }}),
{%- endfor %}
        ),
{%- endif %}
    )
    return tracer.Start(ctx, {{ span_const_name(span.id) }}, opts...)
}
{%- endfor %}
