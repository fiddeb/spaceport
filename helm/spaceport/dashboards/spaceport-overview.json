{
  "uid": "spaceport-overview",
  "title": "Spaceport Overview",
  "tags": [
    "spaceport"
  ],
  "timezone": "browser",
  "editable": true,
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": [
          {
            "text": "All",
            "value": "$__all",
            "selected": true
          },
          {
            "text": "spaceport-api",
            "value": "spaceport-api",
            "selected": false
          },
          {
            "text": "spaceport-pricing-service",
            "value": "spaceport-pricing-service",
            "selected": false
          },
          {
            "text": "spaceport-frontend",
            "value": "spaceport-frontend",
            "selected": false
          }
        ],
        "query": "spaceport-api,spaceport-pricing-service,spaceport-frontend",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "title": "spaceport-api",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "title": "Request Rate \u2014 API",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(rate({__name__=\"http.server.request.duration_count\", \"service.name\"=\"spaceport-api\"}[2m]))",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "#00b6d9" },
          "custom": {
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "title": "Error Rate \u2014 API",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "expr": "(sum(rate({__name__=\"http.server.request.duration_count\", \"service.name\"=\"spaceport-api\", \"http.response.status_code\"=~\"5..\"}[2m])) or vector(0)) / sum(rate({__name__=\"http.server.request.duration_count\", \"service.name\"=\"spaceport-api\"}[2m])) * 100",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "custom": {
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "steps": [
              {
                "color": "#0091b6",
                "value": null
              },
              {
                "color": "#ff6366",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "title": "Latency P50 / P99 \u2014 API",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate({__name__=\"http.server.request.duration_bucket\", \"service.name\"=\"spaceport-api\"}[2m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate({__name__=\"http.server.request.duration_bucket\", \"service.name\"=\"spaceport-api\"}[2m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P50" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#54e9fc" } }] },
          { "matcher": { "id": "byName", "options": "P99" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#007493" } }] }
        ]
      }
    },
    {
      "title": "spaceport-pricing-service",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "collapsed": false
    },
    {
      "title": "Request Rate \u2014 Pricing Service",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "expr": "sum(rate({__name__=\"http.server.request.duration_count\", \"service.name\"=\"spaceport-pricing-service\"}[2m]))",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "#0091b6" },
          "custom": {
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "title": "Error Rate \u2014 Pricing Service",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 10
      },
      "targets": [
        {
          "expr": "(sum(rate({__name__=\"http.server.request.duration_count\", \"service.name\"=\"spaceport-pricing-service\", \"http.response.status_code\"=~\"5..\"}[2m])) or vector(0)) / sum(rate({__name__=\"http.server.request.duration_count\", \"service.name\"=\"spaceport-pricing-service\"}[2m])) * 100",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "custom": {
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "steps": [
              {
                "color": "#0091b6",
                "value": null
              },
              {
                "color": "#ff6366",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "title": "Latency P50 / P99 \u2014 Pricing Service",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate({__name__=\"http.server.request.duration_bucket\", \"service.name\"=\"spaceport-pricing-service\"}[2m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate({__name__=\"http.server.request.duration_bucket\", \"service.name\"=\"spaceport-pricing-service\"}[2m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P50" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#54e9fc" } }] },
          { "matcher": { "id": "byName", "options": "P99" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#007493" } }] }
        ]
      }
    },
    {
      "title": "spaceport-frontend",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "collapsed": false
    },
    {
      "title": "Page Views Rate \u2014 Frontend",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 19
      },
      "targets": [
        {
          "expr": "sum by (\"page.name\") (rate({__name__=\"spaceport.frontend.page_views\"}[2m]))",
          "legendFormat": "{{page.name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "#54e9fc" },
          "custom": {
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "title": "Booking Failure Rate \u2014 Frontend",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 19
      },
      "targets": [
        {
          "expr": "(sum(rate({__name__=\"spaceport.frontend.bookings\", outcome=\"failure\"}[2m])) or vector(0)) / (sum(rate({__name__=\"spaceport.frontend.bookings\"}[2m])) or vector(1)) * 100",
          "legendFormat": "failure %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "custom": {
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "steps": [
              {
                "color": "#0091b6",
                "value": null
              },
              {
                "color": "#ff6366",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "title": "Bookings by Outcome \u2014 Frontend",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 19
      },
      "targets": [
        {
          "expr": "sum by (outcome) (rate({__name__=\"spaceport.frontend.bookings\"}[2m]))",
          "legendFormat": "{{outcome}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00b6d9" } }] },
          { "matcher": { "id": "byName", "options": "failure" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ff6366" } }] }
        ]
      }
    },
    {
      "title": "Bookings",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "collapsed": false
    },
    {
      "title": "Booking Count",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 28
      },
      "targets": [
        {
          "expr": "sum({__name__=\"spaceport.booking.count\"})",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#00b6d9" },
          "thresholds": {
            "steps": [
              { "color": "#005e77", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Pricing Failures",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 28
      },
      "targets": [
        {
          "expr": "sum(rate({__name__=\"spaceport.pricing.failures.count\"}[2m]))",
          "legendFormat": "failures/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "fillOpacity": 20,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "steps": [
              {
                "color": "#0091b6",
                "value": null
              },
              {
                "color": "#ff6366",
                "value": 0.1
              }
            ]
          }
        }
      }
    },
    {
      "title": "Pricing Latency",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 28
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate({__name__=\"spaceport.pricing.request.duration_bucket\"}[2m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "fixed", "fixedColor": "#007493" },
          "custom": {
            "fillOpacity": 10
          }
        }
      }
    }
  ],
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 5
}